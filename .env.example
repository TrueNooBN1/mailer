EMAIL_HOST=smtp.yandex.ru          # или ваш SMTP-сервер
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your@email.com
EMAIL_PASSWORD=yourpassword
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=MyApp


